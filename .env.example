# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rsap
POSTGRES_USER=rsap_user
POSTGRES_PASSWORD=<required-postgres-password>

# Redis - internal Docker service; never expose port 6379 publicly
REDIS_PASSWORD=<required-redis-password>
REDIS_URL=redis://:<required-redis-password>@redis:6379/0

# MinIO
# Webapp backend compatibility
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# File-server internal/public endpoint separation
MINIO_INTERNAL_ENDPOINT=minio:9000
MINIO_INTERNAL_SECURE=false
MINIO_PUBLIC_ENDPOINT=s3.rsap.local
MINIO_PUBLIC_SECURE=true

MINIO_ACCESS_KEY=<required-minio-access-key>
MINIO_SECRET_KEY=<required-minio-secret-key>
MINIO_BUCKET_FACES=faces
MINIO_BUCKET_CAPTURES=captures
MINIO_BUCKET_DOCUMENTS=documents
MINIO_REGION=us-east-1

# JWT
JWT_SECRET=<required-jwt-secret-at-least-32-characters>
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Encryption (AES-256 for camera URLs and sensitive data)
AES_ENCRYPTION_KEY=<required-32-byte-encryption-key>

# Application
APP_ENV=production
APP_DOMAIN=rsap.local
ADMIN_EMAIL=admin@rsap.local
ADMIN_PASSWORD=<required-admin-password>
FILE_SERVER_SERVICE_TOKEN=<required-file-service-token-at-least-16-characters>

# License
LICENSE_SIGNING_SECRET=<required-license-signing-secret>