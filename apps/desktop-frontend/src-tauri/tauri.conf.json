{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RSAP",
  "version": "1.0.0",
  "identifier": "local.rsap.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RSAP - Surveillance Analytics",
        "width": 1600,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8001 ws://127.0.0.1:8001; img-src 'self' blob: data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
